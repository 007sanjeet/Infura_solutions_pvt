datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

enum AdminRole {
  ADMIN
  SUB_ADMIN
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(SUB_ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admins")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model JobCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  iconName    String   @default("Briefcase")
  description String?
  jobs        Job[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("job_categories")
}

model Job {
  id              String        @id @default(uuid())
  title           String
  description     String        // Rich Text content
  requirements    String        // Rich Text content
  skills          String        // JSON string or plain text of skills
  experienceLevel String        // e.g. Entry, Mid, Senior, 3-5 Years
  salaryRange     String        // e.g. $80,000 - $100,000
  location        String        // e.g. London, Remote
  jobType         String        // e.g. Full-Time, Part-Time, Contract
  status          String        @default("ACTIVE") // ACTIVE, INACTIVE
  isFeatured      Boolean       @default(false)
  deadline        DateTime?
  categoryId      String
  category        JobCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  applications    Application[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("jobs")
}

model Application {
  id         String   @id @default(uuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fullName   String
  email      String
  phone      String
  coverLetter String?
  resumePath String   // Path to file
  status     String   @default("PENDING") // PENDING, SHORTLISTED, REJECTED, SELECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("applications")
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model WebContent {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "homepage_hero", "about_us", "why_choose_us"
  value     Json     // JSON content structure for that section
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("website_content")
}

model Testimonial {
  id         String   @id @default(uuid())
  clientName String
  clientRole String
  company    String
  feedback   String
  avatarUrl  String?
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}

model ContactMessage {
  id         String   @id @default(uuid())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("contact_messages")
}

model Media {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  path         String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("media")
}

model Settings {
  id             String   @id @default(uuid())
  logoUrl        String?
  companyName    String   @default("Infura Solutions")
  address        String?
  phone          String?
  email          String?
  socialLinks    Json?    // e.g. { facebook, linkedin, twitter, instagram }
  seoTitle       String?  @default("Infura Solutions - Premium Recruitment Agency")
  seoDescription String?
  seoKeywords    String?
  themeSettings  Json?    // Custom visual details (font, secondary details)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("settings")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  content     String    // Rich text
  excerpt     String?
  author      String    @default("Infura Insights")
  coverImage  String?
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}
